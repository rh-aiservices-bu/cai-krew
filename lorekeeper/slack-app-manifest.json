{
  "display_information": {
    "name": "Lorekeeper",
    "description": "Reviews and prunes mem0 memories with human approval"
  },
  "features": {
    "bot_user": {
      "display_name": "Lorekeeper",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://<lorekeeper-approver-route>/slack/interactions"
    },
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
