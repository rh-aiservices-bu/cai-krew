# Hermes Agent config for OpenShell sandbox (cai-krew variant).
# Includes mem0 memory, Slack gateway with triage, and Mattermost support.
# Rendered by setup-sandbox.sh — do not apply manually.

model:
  default: ${OPENAI_MODEL}
  provider: custom
  base_url: ${OPENAI_BASE_URL}
  api_key: ${OPENAI_API_KEY}

custom_providers:
  - name: ${OPENAI_MODEL}
    base_url: ${OPENAI_BASE_URL}
    api_key: ${OPENAI_API_KEY}
    model: ${OPENAI_MODEL}

toolsets:
  - hermes-cli

plugins:
  enabled: []

agent:
  max_turns: 150
  gateway_timeout: 1800
  api_max_retries: 3
  tool_use_enforcement: auto
  task_completion_guidance: true
  parallel_tool_call_guidance: true
  environment_probe: true
  coding_context: auto
  verify_on_stop: true
  gateway_timeout_warning: 900
  clarify_timeout: 600
  image_input_mode: auto
  reasoning_effort: medium
  verbose: false

terminal:
  backend: local
  timeout: 180
  persistent_shell: true
  auto_source_bashrc: true
  cwd: /workspace
  home_mode: auto

code_execution:
  mode: project
  timeout: 300
  max_tool_calls: 50

delegation:
  inherit_mcp_toolsets: true
  max_iterations: 50
  max_concurrent_children: 3
  max_spawn_depth: 1
  orchestrator_enabled: true

compression:
  enabled: true
  threshold: 0.5
  target_ratio: 0.2
  protect_last_n: 20
  protect_first_n: 3

context:
  engine: compressor

tool_output:
  max_bytes: 50000
  max_lines: 2000
  max_line_length: 2000

tool_loop_guardrails:
  warnings_enabled: true
  hard_stop_enabled: false
  warn_after:
    exact_failure: 2
    same_tool_failure: 3
    idempotent_no_progress: 2
  hard_stop_after:
    exact_failure: 5
    same_tool_failure: 8
    idempotent_no_progress: 5

# mem0 memory (points to the cluster-internal mem0 server)
memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 2200
  user_char_limit: 1375
  provider: mem0_oss

goals:
  max_turns: 20

kanban:
  auto_decompose: true
  auto_decompose_per_tick: 3

skills:
  external_dirs: []
  template_vars: true
  inline_shell: false

curator:
  enabled: true
  interval_hours: 168
  min_idle_hours: 2
  stale_after_days: 30

lsp:
  enabled: true
  wait_mode: document
  wait_timeout: 5.0
  install_strategy: auto

model_catalog:
  enabled: true
  url: https://hermes-agent.nousresearch.com/docs/api/model-catalog.json
  ttl_hours: 1

security:
  redact_secrets: true
  tirith_enabled: true

approvals:
  mode: manual
  timeout: 60

display:
  compact: false
  streaming: true
  show_reasoning: false
  inline_diffs: true
  file_mutation_verifier: true

logging:
  level: INFO
  max_size_mb: 5
  backup_count: 3

file_read_max_chars: 100000

# Slack gateway + triage
slack:
  require_mention: true
  strict_mention: true
  free_response_channels: ''
  allowed_channels: ''
  extra:
    slack_inject_context: true
    slack_context_limit: 20
    triage: ${SLACK_TRIAGE}
    triage_max_tokens: 1564
    triage_timeout: 30
    triage_context_limit: 3
    triage_memory_limit: 5
    triage_guided_choice: true
    triage_model: ''
    triage_prompt: |
      Your Slack display name is **{bot_name}**.
      - If the message @mentions or is clearly directed at a different person or bot (not {bot_name}), say NO.
      - If another bot or person is already actively responding and the new message is a natural follow-up with no explicit @mention of {bot_name}, say NO.
      - Imperative language without an explicit @mention of {bot_name} means the command is for whoever is already active. Say NO.

      Reply YES if someone is asking something you can genuinely help with, has directly addressed you, or the conversation has reached a natural opening where a knowledgeable colleague would speak up.
      Reply NO if the conversation is social/casual, the question is directed at a specific human, or jumping in would feel like an interruption.

      Reply with only YES or NO.

# Mattermost gateway
mattermost:
  require_mention: true
  free_response_channels: ''
  allowed_channels: ''
  channel_prompts: {}
