# Local environment override for docker-compose
# Copy this to .env.local and fill in your actual secrets
# Do NOT commit real secrets to version control

# LLM Provider (custom via LiteLLM)
HERMES_ENV_MODEL_DEFAULT=
HERMES_ENV_MODEL_PROVIDER=custom
HERMES_ENV_MODEL_BASE_URL=
HERMES_ENV_MODEL_API_KEY=sk-your-api-key-here

# mem0 Integration
HERMES_ENV_MEM0_URL=
HERMES_ENV_MEM0_AGENT_ID=slack-hermes
HERMES_ENV_MEM0_CUSTOM_INSTRUCTIONS=Always refer to the user by their actual name in stored memories. The user name can be derived from the user_id field. When a new fact relates to the same subject as an existing memory, prefer UPDATE over ADD and merge the information into a single consolidated memory. Only use ADD when the fact is genuinely new with no overlap.

# Slack Socket Mode (required for containers behind NAT/OpenShift)
HERMES_ENV_SLACK_BOT_TOKEN=xoxb-your-actual-bot-token
HERMES_ENV_SLACK_APP_TOKEN=xapp-1-your-actual-app-token
HERMES_ENV_SLACK_SOCKET_MODE=true
HERMES_ENV_SLACK_ALLOWED_USERS=
HERMES_ENV_SLACK_HOME_CHANNEL=

# Optional: enable all users (remove allowlist)
# HERMES_ENV_GATEWAY_ALLOW_ALL_USERS=true
